# Port the platform listens on (nginx proxies the public domain to this)
PORT=4500

# Admin login password (the GUI asks only for this password)
ADMIN_PASSWORD=change-me

# Secret used to sign JWT session tokens. Use a long random string.
JWT_SECRET=replace-with-a-long-random-secret

# How long a login session stays valid
JWT_EXPIRES_IN=7d

# Secret used to validate incoming GitHub webhooks (set the same value in GitHub)
GITHUB_WEBHOOK_SECRET=replace-with-a-random-webhook-secret
